---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getProjects } from '../utils/content';

const projects = await getProjects();
---

<BaseLayout title="项目集 - Kyle">
  <Navigation client:load />
  
  <main class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-slate-300 text-sm mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
          Projects
        </div>
        <h1 class="text-4xl font-bold text-slate-50 mb-4">项目集</h1>
        <p class="text-slate-400 max-w-2xl leading-relaxed">
          汇聚 AI 开发与量化交易的实践项目，每一个项目都是学习过程中的里程碑。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projects.length > 0 ? (
          projects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              category={project.data.category}
              tags={project.data.tags}
              github={project.data.github}
              demo={project.data.demo}
              slug={project.id}
            />
          ))
        ) : (
          <div class="col-span-full text-center py-24 text-slate-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 opacity-50"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
            <p class="text-lg mb-2">项目正在整理中</p>
            <p class="text-sm">精彩内容即将上线，敬请期待...</p>
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
