---
interface Props {
  title: string;
  description: string;
  category: 'ai' | 'quant' | 'other';
  tags: string[];
  github?: string;
  demo?: string;
  slug: string;
}

const { title, description, category, tags, github, demo, slug } = Astro.props;

const categoryConfig = {
  ai: { label: 'AI 项目', gradient: 'from-violet-500 to-blue-500' },
  quant: { label: '量化项目', gradient: 'from-emerald-500 to-amber-500' },
  other: { label: '其他项目', gradient: 'from-slate-500 to-slate-400' },
};

const config = categoryConfig[category];
---

<div class="group relative p-6 rounded-2xl bg-white/[0.03] border border-white/[0.08] backdrop-blur-sm hover:bg-white/[0.06] hover:border-white/[0.15] transition-all duration-300 overflow-hidden">
  <div class={`absolute top-0 left-0 w-full h-1 bg-gradient-to-r ${config.gradient} opacity-0 group-hover:opacity-100 transition-opacity`} />
  
  <div class="flex items-center gap-2 mb-4">
    <div class={`w-8 h-8 rounded-lg bg-gradient-to-br ${config.gradient} flex items-center justify-center text-white text-xs font-bold`}>
      {config.label.charAt(0)}
    </div>
    <span class="text-xs text-slate-500">{config.label}</span>
  </div>
  
  <h3 class="text-xl font-semibold text-slate-50 mb-2 group-hover:text-violet-300 transition-colors">
    {title}
  </h3>
  
  <p class="text-sm text-slate-400 mb-4 leading-relaxed line-clamp-3">
    {description}
  </p>
  
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map(tag => (
      <span class="px-2 py-0.5 rounded-md bg-white/5 text-xs text-slate-500">
        {tag}
      </span>
    ))}
  </div>
  
  <div class="flex items-center gap-3">
    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs text-slate-400 hover:text-slate-50 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        源码
      </a>
    )}
    {demo && (
      <a
        href={demo}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs text-slate-400 hover:text-slate-50 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
        演示
      </a>
    )}
  </div>
</div>
