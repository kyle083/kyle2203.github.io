---
import { formatDate } from '../utils/content';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: 'ai' | 'quant' | 'other';
  tags: string[];
  slug: string;
}

const { title, description, pubDate, category, tags, slug } = Astro.props;

const categoryConfig = {
  ai: { label: 'AI', color: 'from-violet-500/20 to-blue-500/20 text-violet-300 border-violet-500/30' },
  quant: { label: '量化', color: 'from-emerald-500/20 to-amber-500/20 text-emerald-300 border-emerald-500/30' },
  other: { label: '其他', color: 'from-slate-500/20 to-slate-400/20 text-slate-300 border-slate-500/30' },
};

const config = categoryConfig[category];
---

<a
  href={`${import.meta.env.BASE_URL}blog/${slug}`}
  class="group block p-6 rounded-2xl bg-white/[0.03] border border-white/[0.08] backdrop-blur-sm hover:bg-white/[0.06] hover:border-white/[0.15] transition-all duration-300"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-gradient-to-r ${config.color} border`}>
      {config.label}
    </span>
    <time class="text-xs text-slate-500 shrink-0">{formatDate(pubDate)}</time>
  </div>
  
  <h3 class="text-lg font-semibold text-slate-50 group-hover:text-violet-300 transition-colors mb-2 line-clamp-1">
    {title}
  </h3>
  
  <p class="text-sm text-slate-400 line-clamp-2 mb-4 leading-relaxed">
    {description}
  </p>
  
  <div class="flex flex-wrap gap-2">
    {tags.map(tag => (
      <span class="px-2 py-0.5 rounded-md bg-white/5 text-xs text-slate-500">
        #{tag}
      </span>
    ))}
  </div>
</a>
