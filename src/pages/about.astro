---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer.astro';
import Timeline from '../components/Timeline';
---

<BaseLayout title="关于我 - Kyle">
  <Navigation client:load />
  
  <main class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Profile Header */}
      <div class="mb-16">
        <div class="flex flex-col md:flex-row items-start md:items-center gap-8">
          <div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-violet-500 via-purple-500 to-emerald-500 flex items-center justify-center text-white text-3xl font-bold shadow-xl shadow-violet-500/20">
            K
          </div>
          <div>
            <h1 class="text-4xl font-bold text-slate-50 mb-2">关于我</h1>
            <p class="text-slate-400 mb-4">数字经济 × 人工智能 | 摄影 × 音乐</p>
            <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500">
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                浙江杭州
              </span>
              <span class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/></svg>
                浙江财经大学
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        {/* Left: Bio */}
        <div>
          <h2 class="text-xl font-bold text-slate-50 mb-6">自我介绍</h2>
          <div class="prose prose-invert max-w-none">
            <p class="text-slate-300 leading-relaxed mb-4">
              你好，我是 Kyle，一名对 AI 和量化交易充满热情的终身学习者。
              本科就读于浙江财经大学，主修数字经济，辅修人工智能。
            </p>
            <p class="text-slate-300 leading-relaxed mb-4">
              我相信技术与金融的结合能够创造出巨大的价值。在 AI 领域，我专注于
              大型语言模型的应用开发；在量化领域，我致力于用数据驱动的方式
              理解市场规律，构建稳健的交易策略。
            </p>
            <p class="text-slate-300 leading-relaxed mb-4">
              除了技术，我还热爱摄影和音乐。摄影让我学会观察世界的美，
              音乐则是我思考和放松的方式。
            </p>
          </div>

          <h2 class="text-xl font-bold text-slate-50 mb-6 mt-10">兴趣爱好</h2>
          <div class="flex flex-wrap gap-3">
            {['编程开发', '人工智能', '量化交易', '摄影', '音乐'].map((hobby) => (
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm text-slate-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                {hobby}
              </span>
            ))}
          </div>

          <h2 class="text-xl font-bold text-slate-50 mb-6 mt-10">联系方式</h2>
          <div class="flex flex-wrap gap-3">
            <a
              href="mailto:kaiwang021207@163.com"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm text-slate-300 hover:bg-white/10 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              kaiwang021207@163.com
            </a>
            <a
              href="https://github.com/kyle2203"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm text-slate-300 hover:bg-white/10 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              GitHub
            </a>
          </div>
        </div>

        {/* Right: Timeline */}
        <div>
          <h2 class="text-xl font-bold text-slate-50 mb-6">学习历程</h2>
          <Timeline client:load />
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
